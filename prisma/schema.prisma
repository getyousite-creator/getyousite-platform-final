// Prisma Schema - PostgreSQL with JSONB
// 
// Optimized for:
// - Flexible site blueprints (JSONB)
// - Soft deletes (deletedAt)
// - Indexing for performance
// - Partitioning-ready for analytics

// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  tier          String    @default("starter")
  credits       Int       @default(0)
  role          Role      @default(USER)
  emailVerified DateTime? @map("email_verified")
  
  // Relations
  profile       Profile?
  sites         Site[]
  refreshTokens RefreshToken[]
  subscriptions Subscription[]
  apiKeys       ApiKey[]
  // Strategic Intelligence Relations
  churnPredictions ChurnPrediction[]
  retentionActions RetentionAction[]
  consent          Consent?
  
  // Timestamps
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at") // Soft delete
  
  // Indexes
  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Profile {
  id                 String  @id @db.Uuid
  user               User    @relation(fields: [id], references: [id], onDelete: Cascade)
  fullName           String? @map("full_name")
  avatarUrl          String? @map("avatar_url")
  phone              String?
  stripeCustomerId   String? @unique @map("stripe_customer_id")
  subscriptionStatus String? @map("subscription_status")
  planId             String? @map("plan_id")
  subscriptionId     String? @map("subscription_id")
  paypalPayerId      String? @map("paypal_payer_id")

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum Role {
  USER
  ADMIN
  PREMIUM
}

// ============================================================================
// SITE & BLUEPRINT
// ============================================================================

model Site {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  vision      String?
  
  // JSONB for flexible blueprint storage
  blueprint   Json     @db.JsonB
  
  // Domain configuration
  customDomain String? @unique @map("custom_domain")
  subdomain    String  @unique @map("sub_domain")
  
  // Status
  status      SiteStatus @default(DRAFT)
  isPublished Boolean    @default(false) @map("is_published")
  
  // Relations
  userId      String   @db.Uuid @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  deployments Deployment[]
  analytics   Analytics[]
  seoAudits   SeoAudit[]
  media       Media[]
  leads       StoreLead[]
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at") // Soft delete
  publishedAt DateTime? @map("published_at")
  
  // Indexes
  @@index([userId])
  @@index([subdomain])
  @@index([customDomain])
  @@index([status])
  @@index([deletedAt])
  @@map("stores")
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================================================
// DEPLOYMENT
// ============================================================================

model Deployment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId       String   @db.Uuid @map("site_id")
  site         Site     @relation(fields: [siteId], references: [id])
  
  // Deployment info
  version      Int
  buildTime    Int? @map("build_time") // in milliseconds
  buildStatus  BuildStatus @default(PENDING) @map("build_status")
  
  // Vercel/Cloudflare IDs
  deploymentId String? @map("deployment_id")
  vercelUrl    String? @map("vercel_url")
  
  // Assets
  assets       Json? @db.JsonB // CDN URLs
  
  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  
  // Indexes
  @@index([siteId])
  @@index([buildStatus])
  @@index([createdAt])
  @@map("deployments")
}

enum BuildStatus {
  PENDING
  OPTIMIZING
  PROVISIONING
  SECURITY_SCAN
  SUCCESS
  FAILED
}

// ============================================================================
// ANALYTICS (Partitioning-ready)
// ============================================================================

model Analytics {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId    String   @db.Uuid @map("site_id")
  site      Site     @relation(fields: [siteId], references: [id])
  
  // Legacy Aggregated Fields (Matching SQL)
  path      String?  @default("/")
  views     Int?     @default(0)
  visitors  Int?     @default(0)
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  timestamp DateTime @default(now())
  
  // Event data (Flexible)
  eventType String?  @map("event_type") // pageview, click, conversion, etc.
  eventData Json?    @db.JsonB @map("event_data") // Flexible event data
  
  // Visitor info
  visitorId String? @map("visitor_id")
  sessionId String? @map("session_id")
  referrer  String? @map("referrer")
  userAgent String? @map("user_agent")
  
  // Timestamps (for partitioning)
  createdAt DateTime @default(now()) @map("created_at")
  
  // Indexes
  @@index([siteId])
  @@index([createdAt])
  @@index([visitorId])
  
  @@map("analytics")
}

model SeoAudit {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId               String   @db.Uuid @map("store_id")
  site                 Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  overallScore         Int?     @default(0) @map("overall_score")
  seoScore             Int?     @default(0) @map("seo_score")
  performanceScore     Int?     @default(0) @map("performance_score")
  accessibilityScore   Int?     @default(0) @map("accessibility_score")
  bestPracticesScore   Int?     @default(0) @map("best_practices_score")
  issues               Json?    @db.JsonB
  recommendations      Json?    @db.JsonB
  lcp                  Float?
  fid                  Float?
  cls                  Float?
  targetKeywords       String[] @map("target_keywords")
  rankingPositions     Json?    @db.JsonB @map("ranking_positions")
  analyzedAt           DateTime @default(now()) @map("analyzed_at")

  @@index([siteId, analyzedAt])
  @@map("seo_audits")
}

model Media {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId        String   @db.Uuid @map("store_id")
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  filename      String
  originalName  String   @map("original_name")
  mimeType      String   @map("mime_type")
  size          Int
  url           String
  thumbnailUrl  String?  @map("thumbnail_url")
  storagePath   String   @map("storage_path")
  alt           String?
  caption       String?
  width         Int?
  height        Int?
  aiTags        String[] @map("ai_tags")
  aiDescription String?  @map("ai_description")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("media")
}

model SystemLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level     String
  source    String
  message   String
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("system_logs")
}

model StoreLead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siteId    String   @db.Uuid @map("store_id")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  email     String
  fullName  String?  @map("full_name")
  message   String?
  metadata  Json?    @db.JsonB
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([siteId])
  @@map("store_leads")
}

// ============================================================================
// SUBSCRIPTION & BILLING
// ============================================================================

model Subscription {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @db.Uuid @map("user_id")
  user           User     @relation(fields: [userId], references: [id])
  
  // Plan info
  plan           PlanType @default(FREE)
  status         SubscriptionStatus @default(ACTIVE)
  
  // Billing
  stripeCustomerId String? @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  
  // Limits
  sitesLimit     Int      @default(1) @map("sites_limit")
  storageLimit   Int      @default(100) @map("storage_limit") // MB
  
  // Timestamps
  currentPeriodStart DateTime @default(now()) @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  cancelledAt        DateTime? @map("cancelled_at")
  
  // Indexes
  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

enum PlanType {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
}

// ============================================================================
// AUDIT LOGS (For security & compliance)
// ============================================================================

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @db.Uuid @map("user_id")
  action    String // CREATE, UPDATE, DELETE, LOGIN, etc.
  resource  String // USER, SITE, DEPLOYMENT, etc.
  resourceId String?  @map("resource_id")
  
  // Change details
  oldValue  Json? @db.JsonB @map("old_value")
  newValue  Json? @db.JsonB @map("new_value")
  
  // Context
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  
  // Indexes
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  
  // Note: Partition by createdAt for large-scale deployments
  @@map("audit_logs")
}

// ============================================================================
// API KEYS (For developer access)
// ============================================================================

model ApiKey {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  
  name        String
  key         String   @unique // Hashed
  prefix      String   // First 8 chars for identification
  
  // Permissions
  permissions String[] // ['sites:read', 'sites:write', etc.]
  
  // Usage
  lastUsedAt  DateTime? @map("last_used_at")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime? @map("expires_at")
  
  // Indexes
  @@index([userId])
  @@index([key])
  @@map("api_keys")
}
// ============================================================================
// STRATEGIC INTELLIGENCE (AI-Driven Patterns)
// ============================================================================

model ChurnPrediction {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @db.Uuid @map("user_id")
  user             User     @relation(fields: [userId], references: [id])
  
  churnProbability Float    @map("churn_probability") // 0 to 100
  riskLevel        String   @map("risk_level") // low, medium, high, critical
  factors          String[] // Identified risk patterns
  recommendedAction String?  @map("recommended_action")
  
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([riskLevel])
  @@map("churn_predictions")
}

model RetentionAction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  
  type        String   // discount, support, tip
  trigger     String   // High churn risk, inactivity, etc.
  content     String
  
  deliveredAt DateTime @default(now()) @map("delivered_at")

  @@index([userId])
  @@map("retention_actions")
}

model Consent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @db.Uuid @map("user_id")
  user             User     @relation(fields: [userId], references: [id])
  
  analyticsConsent Boolean  @default(false) @map("analytics_consent")
  marketingConsent Boolean  @default(false) @map("marketing_consent")
  
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_consents")
}

// ============================================================================
// BACKUP (For storage & disaster recovery)
// ============================================================================

model Backup {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  s3Key       String   @map("s3_key")
  size        Int
  status      BackupStatus @default(PENDING)
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  
  @@index([status])
  @@index([completedAt])
  @@map("backups")
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}
